# Ghana SHS LMS - Frontend Environment Variables
# Copy this file to .env and fill in actual values.
# Then run:  node scripts/generate-env.js
# to regenerate assets/js/env.js from this file.

# ─── Environment ─────────────────────────────────────────────
# Options: development | staging | production
APP_ENV=development

# ─── API ─────────────────────────────────────────────────────
# The base URL of the lms-api backend (no trailing slash)
API_BASE_URL=http://localhost:8000

# ─── Staging example ─────────────────────────────────────────
# APP_ENV=staging
# API_BASE_URL=https://staging-api.ghanalms.edu.gh

# ─── Production example ──────────────────────────────────────
# APP_ENV=production
# API_BASE_URL=https://api.ghanalms.edu.gh
